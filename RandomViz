### II.2 — Action Classification: Complete Decision Tree

```python
def classify_action(row, tick, eps_factor=0.1):
    """
    Fully deterministic classification. 
    Every row gets exactly one label.
    No label = 'OTHER' is a model failure, not a data property.
    
    If OTHER > 5% of events, the tick size is wrong
    or the data has fractional-tick moves (corporate action?).
    """
    bc  = row['bid_chg']
    ac  = row['ask_chg']
    bvc = row['bid_vol_chg']
    avc = row['ask_vol_chg']
    eps = tick * eps_factor

    # --- PRICE MOVES ---
    # Symmetric reprice (market-wide move or full quote shift)
    if bc > eps and ac > eps:
        # Both sides improve? Unusual. Spread narrowing.
        if abs(abs(bc) - abs(ac)) < eps:
            return 'REPRICE_UP_SYMMETRIC'
        return 'REPRICE_UP'
    
    if bc < -eps and ac < -eps:
        if abs(abs(bc) - abs(ac)) < eps:
            return 'REPRICE_DOWN_SYMMETRIC'
        return 'REPRICE_DOWN'

    # Spread change: one price moves, other anchored
    if bc > eps and ac < -eps:
        return 'SPREAD_NARROWING'   # both sides improve
    
    if bc < -eps and ac > eps:
        return 'SPREAD_WIDENING'    # both sides retreat

    # One-sided price improvement (diming = stepping ahead)
    if bc > eps and abs(ac) < eps:
        return 'BID_DIME'      # new best bid placed
    
    if bc < -eps and abs(ac) < eps:
        return 'BID_FADE'      # best bid withdrawn/repriced down
    
    if ac < -eps and abs(bc) < eps:
        return 'ASK_DIME'      # new best ask placed
    
    if ac > eps and abs(bc) < eps:
        return 'ASK_FADE'      # best ask withdrawn/repriced up

    # --- VOLUME ONLY MOVES (price stable) ---
    if abs(bc) < eps and abs(ac) < eps:
        # Priority: if both sides changed, bid takes precedence
        # (rare — usually only one side changes per event)
        if bvc > 0 and avc == 0:
            return 'BID_JOIN'      # size added at best bid
        if bvc < 0 and avc == 0:
            return 'BID_CANCEL'    # size removed at best bid
        if avc < 0 and bvc == 0:
            return 'ASK_JOIN'      # size added at best ask
        if avc > 0 and bvc == 0:
            return 'ASK_CANCEL'    # size removed at best ask
        if bvc > 0 and avc > 0:
            return 'BOTH_JOIN'     # simultaneous adds (very rare)
        if bvc < 0 and avc < 0:
            return 'BOTH_CANCEL'   # simultaneous removes
        if bvc > 0 and avc < 0:
            return 'BID_JOIN_ASK_CANCEL'
        if bvc < 0 and avc > 0:
            return 'BID_CANCEL_ASK_JOIN'
        # Volume genuinely unchanged — stale/duplicate event
        return 'NO_CHANGE'

    return 'OTHER'

# VALIDATION: OTHER should be < 5%
action_dist = bbo_l0['action_type'].value_counts(normalize=True)
other_pct = action_dist.get('OTHER', 0)
if other_pct > 0.05:
    print(f"WARNING: {other_pct:.1%} events classified OTHER.")
    print("Diagnosing...")
    other_rows = bbo_l0[bbo_l0['action_type']=='OTHER']
    print("Unique (bid_chg, ask_chg) combos in OTHER:")
    print(other_rows.groupby(
        [other_rows['bid_chg'].round(4),
         other_rows['ask_chg'].round(4)]
    ).size().sort_values(ascending=False).head(20))
    # Common cause: fractional ticks from corporate action
    # or price in wrong units (paise vs rupees)
