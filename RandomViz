### II.4 — Statistical Validity Gates

```python
def validity_gate(df, group_cols, outcome_col, min_n=200,
                   min_regime_n=500):
    """
    Before trusting any number in the result table,
    it must pass these gates.
    
    Returns filtered df with validity flags.
    """
    stats = (df.groupby(group_cols)[outcome_col]
               .agg(['count','mean','std','sem'])
               .reset_index())
    
    # Gate 1: Minimum sample size
    stats['pass_n'] = stats['count'] >= min_n
    
    # Gate 2: Confidence interval width relative to signal
    # If CI > |mean|, the signal is noise
    stats['ci_95'] = 1.96 * stats['sem']
    stats['signal_to_noise'] = (
        stats['mean'].abs() / stats['ci_95'].clip(lower=1e-10)
    )
    stats['pass_snr'] = stats['signal_to_noise'] > 1.0
    
    # Gate 3: Not dominated by a single timestamp
    # (regime event cluster = not independent observations)
    # Compute: what fraction of obs are in the most common
    # 1-minute bucket?
    concentration = (
        df.assign(minute=df['ts_ms'] // 60_000)
          .groupby(group_cols + ['minute'])
          .size()
          .reset_index(name='minute_n')
          .groupby(group_cols)
          .apply(lambda g: g['minute_n'].max() / g['minute_n'].sum())
          .reset_index(name='max_minute_concentration')
    )
    stats = stats.merge(concentration, on=group_cols)
    stats['pass_concentration'] = (
        stats['max_minute_concentration'] < 0.50
    )
    # If > 50% of observations are in a single minute,
    # you are measuring one event, not a pattern.
    
    # Gate 4: Stationarity check (rough)
    # Split into first-half / second-half of day.
    # If mean in first half vs second half differ by > 2 std,
    # the effect is not stable across the day.
    # (Implement as needed — placeholder flag)
    stats['pass_stationarity'] = True  # TODO: implement
    
    stats['all_pass'] = (
        stats['pass_n'] & 
        stats['pass_snr'] & 
        stats['pass_concentration']
    )
    
    dropped = stats[~stats['all_pass']]
    if len(dropped) > 0:
        print(f"\nDROPPED {len(dropped)} buckets (failed gates):")
        print(dropped[group_cols + ['count','signal_to_noise',
                                     'max_minute_concentration',
                                     'pass_n','pass_snr',
                                     'pass_concentration']]
              .to_string())
    
    return stats[stats['all_pass']]
```

