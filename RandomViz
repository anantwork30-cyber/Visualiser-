    export_data = {"meta": {}, "futures": [], "books": {}}
    
    # Meta
    export_data["meta"] = {
        "date": str(DATE_ID),
        "underlying": "RELIANCE", 
        "window_start_ms": start_ms,
        "window_end_ms": end_ms,
        "window_duration_min": 
            round((end_ms - start_ms) / 60000, 1),
        "generated_at": str(datetime.now()),
        "strikes": [
            {
                "rdsId": rds_id,
                "strike": info["strike"],
                "kind": info["kind"],
