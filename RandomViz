const DATA = /* embedded JSON */;

// ---- PRECOMPUTE ON LOAD (do once) ----
let allEvents = [];   
// merged sorted array of ALL events across all strikes
// each entry: {ts, type, rdsId, dataIndex}
// sorted by ts ASC, then by type order SNAP < ENTER < TRADE

let maxVolPerStrike = {};  
// {rdsId: {bid: maxBidVol, ask: maxAskVol}}
// precomputed from ALL snaps in window

let lastSnapState = {};    
// {rdsId: {l0:{bp,bv,ap,av}, l1:..., l2:..., imc_bp, imc_ap}}
// updated as we scrub forward

let futuresCursor = 0;     
// index into DATA.futures for current time

let currentEventIdx = 0;

// ---- TIMESTAMP INDEX ----
// Binary search helper for O(log n) lookup
function binarySearch(arr, target, key) {
    let lo = 0, hi = arr.length - 1;
    while (lo <= hi) {
        const mid = (lo + hi) >> 1;
        if (arr[mid][key] < target) lo = mid + 1;
        else if (arr[mid][key] > target) hi = mid - 1;
        else return mid;
    }
    return lo;
}

// ---- RENDER (called every navigation) ----
function renderAtIndex(idx) {
    currentEventIdx = idx;
    const evt = allEvents[idx];
    
    // Update book state up to this point
    // (walk forward/back from last known state)
    updateBookState(idx);
    
    // Update DOM — only changed elements
    updateAllLadders();
    updateFuturesCursor(evt.ts);
    updateScrubberLabel(idx, evt);
    updateTradeMarkers();
    updateEnterMarkers();
}

// ---- DOM UPDATES ----
// Each price/vol element has a unique ID:
// bid-price-{rdsId}-{level} 
// bid-vol-bar-{rdsId}-{level}
// ask-price-{rdsId}-{level}
// ask-vol-bar-{rdsId}-{level}
// Update by getElementById — never innerHTML of parent

// ---- KEYBOARD ----
document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight') navigate(+1);
    if (e.key === 'ArrowLeft')  navigate(-1);
    if (e.key === 't' || e.key === 'T') nextOfType('TRADE');
    if (e.key === 'e' || e.key === 'E') nextOfType('ENTER');
    if (e.key === 's' || e.key === 'S') nextBBOChange();
    if (e.key === 'f' || e.key === 'F') toggleFutures();
    if (['1','2','3','4','5'].includes(e.key)) 
        highlightStrike(parseInt(e.key)-1);
});

// ---- SCRUBBER ----
// Debounce to requestAnimationFrame
let rafPending = false;
scrubberEl.addEventListener('input', () => {
    if (!rafPending) {
        rafPending = true;
        requestAnimationFrame(() => {
            renderAtIndex(parseInt(scrubberEl.value));
            rafPending = false;
        });
    }
});

// ---- INIT ----
window.addEventListener('load', () => {
    buildAllEvents();
    precomputeMaxVols();
    buildFuturesCanvas();
    renderAtIndex(0);
});

