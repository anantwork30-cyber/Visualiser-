bbo_with_regime = bbo_with_regime.sort_values(
    ['ts_ms','foreign_sequence_number_'])

# Only look at level_index_ == 0 (top of book)
bbo_l0 = bbo_with_regime[
    bbo_with_regime['level_index_']==0].copy()

bbo_l0['prev_bid'] = bbo_l0['bid_price'].shift(1)
bbo_l0['prev_ask'] = bbo_l0['ask_price'].shift(1)
bbo_l0['prev_bid_vol'] = bbo_l0['bid_vol'].shift(1)
bbo_l0['prev_ask_vol'] = bbo_l0['ask_vol'].shift(1)

bbo_l0['bid_chg'] = bbo_l0['bid_price'] - bbo_l0['prev_bid']
bbo_l0['ask_chg'] = bbo_l0['ask_price'] - bbo_l0['prev_ask']
bbo_l0['bid_vol_chg'] = bbo_l0['bid_vol'] - bbo_l0['prev_bid_vol']
bbo_l0['ask_vol_chg'] = bbo_l0['ask_vol'] - bbo_l0['prev_ask_vol']

# Find tick size from data
tick = bbo_l0['bid_chg'].abs()[
       bbo_l0['bid_chg'].abs() > 0].mode()[0]
print(f"Detected tick size: {tick}")

def classify_action(row):
    bc, ac = row['bid_chg'], row['ask_chg']
    bvc, avc = row['bid_vol_chg'], row['ask_vol_chg']
    t = tick
    eps = t * 0.1
    
    # Both prices move same direction = full reprice
    if bc > eps and ac > eps:
        return 'REPRICE_UP'
    if bc < -eps and ac < -eps:
        return 'REPRICE_DOWN'
    
    # One side moves, other stable
    if bc > eps and abs(ac) < eps:
        return 'BID_DIME'      # bid improved
    if bc < -eps and abs(ac) < eps:
        return 'BID_FADE'      # bid retreated
    if ac < -eps and abs(bc) < eps:
        return 'ASK_DIME'      # ask improved
    if ac > eps and abs(bc) < eps:
        return 'ASK_FADE'      # ask retreated
    
    # Volume only changes (joins/cancels same level)
    if abs(bc) < eps and abs(ac) < eps:
        if bvc > 0:
            return 'BID_JOIN'
        if bvc < 0:
            return 'BID_CANCEL'
        if avc > 0:
            return 'ASK_JOIN'
        if avc < 0:
            return 'ASK_CANCEL'
    
    return 'OTHER'

bbo_l0['action_type'] = bbo_l0.apply(
    classify_action, axis=1)

