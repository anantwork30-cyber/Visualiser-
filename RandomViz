CHECKPOINTS = {}

def checkpoint(name, df, key_stats=None):
    """
    Save intermediate state at each step.
    If you re-run and a checkpoint changes,
    you know exactly where the pipeline diverged.
    """
    import hashlib, json
    
    shape = df.shape
    col_hash = hashlib.md5(
        str(sorted(df.columns.tolist())).encode()
    ).hexdigest()[:8]
    
    if key_stats is None:
        key_stats = {}
    key_stats.update({
        'rows': shape[0],
        'cols': shape[1],
        'col_hash': col_hash,
    })
    
    CHECKPOINTS[name] = key_stats
    print(f"\n✓ CHECKPOINT [{name}]: {key_stats}")
    return df

