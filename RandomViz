```python
def regime_type_test(trades_annotated, alpha=0.05):
    """
    Tests whether regime can be treated as a time-period 
    step function.
    
    If TRUE: merge_asof (forward-fill) is valid.
    If FALSE: must build explicit regime windows.
    """
    regime_ts = (
        trades_annotated
        .filter(pl.col('regime').is_not_null())
        .sort('exchange_timestamp_')
        .select(['exchange_timestamp_', 'regime'])
        .to_pandas()
    )
    
    # Test: within a 1-second window, is regime constant?
    regime_ts['second'] = (
        regime_ts['exchange_timestamp_'] // 1_000_000_000
    )
    within_second_variation = (
        regime_ts.groupby('second')['regime']
        .nunique()
    )
    
    pct_stable_seconds = (
        within_second_variation == 1
    ).mean()
    
    print(f"Seconds with constant regime: {pct_stable_seconds:.1%}")
    print(f"Seconds with mixed regime:    "
          f"{1-pct_stable_seconds:.1%}")
    
    if pct_stable_seconds > 0.95:
        print("\nCONCLUSION: Regime is a time-period label.")
        print("merge_asof forward-fill is VALID.")
        regime_structure = 'period'
    else:
        print("\nCONCLUSION: Regime is per-trade label.")
        print("merge_asof will create phantom assignments.")
        print("Build explicit regime windows before joining.")
        regime_structure = 'per_trade'
    
    return regime_structure

regime_structure = regime_type_test(trades_annotated)
# Store result; downstream code branches on this.
```

